// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  plan         String   @default("free")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      UserProfile?
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  suggestions  AiSuggestion[]
  reports      Report[]
  wallets      Wallet[]
  transfers    Transfer[]
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  monthlyIncome   Int
  monthlyExpense  Int?
  currentSavings  Int?
  incomeCurrency  String   @default("IDR")
  occupation      String?
  dependents      Int      @default(0)
  financialGoals  Json     @default("[]")
  riskProfile     String?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String  @id @default(uuid())
  userId    String?
  name      String
  type      String
  color     String?
  icon      String?
  sortOrder Int     @default(0)
  isDefault Boolean @default(false)

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  categoryId      String
  walletId        String?
  type            String
  amount          Decimal  @db.Decimal(15, 2)
  currency        String   @default("IDR")
  description     String?
  transactionDate DateTime
  createdAt       DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  wallet   Wallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String
  name           String
  type           String   @default("bank")
  bankCode       String?
  color          String?
  icon           String?
  initialBalance Decimal  @default(0) @db.Decimal(15, 2)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfersOut Transfer[]    @relation("TransferOut")
  transfersIn  Transfer[]    @relation("TransferIn")
}

model Transfer {
  id           String   @id @default(uuid())
  userId       String
  fromWalletId String
  toWalletId   String
  amount       Decimal  @db.Decimal(15, 2)
  note         String?
  transferDate DateTime
  createdAt    DateTime @default(now())

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromWallet Wallet @relation("TransferOut", fields: [fromWalletId], references: [id], onDelete: Cascade)
  toWallet   Wallet @relation("TransferIn", fields: [toWalletId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String    @id @default(uuid())
  userId      String
  categoryId  String
  limitAmount Decimal   @db.Decimal(15, 2)
  period      String    @default("monthly")
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
}

model AiSuggestion {
  id        String   @id @default(uuid())
  userId    String
  type      String
  content   String
  metadata  Json?
  isRead    Boolean  @default(false)
  isApplied Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(uuid())
  userId      String
  periodType  String
  periodStart DateTime
  periodEnd   DateTime
  summaryData Json
  fileUrl     String?
  status      String   @default("generated")
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
